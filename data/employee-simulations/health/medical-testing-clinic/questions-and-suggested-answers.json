          "suggestedAnswer": "always_short_summary",
          "options": [
            { "id": "always_short_summary", "label": "Sim, um resumo curto com resultado e pendências" },
            { "id": "only_when_handoff", "label": "Somente quando houver encaminhamento humano" },
            { "id": "no_summary", "label": "Não gerar resumo" }
          ],
          "includeInPromptAs": "output.serviceSummary"
