          "required": true,
          "suggestedAnswer": ["confirm_understanding", "objective_questions", "clear_result", "pending_items", "human_approval"],
          "options": [
            { "id": "confirm_understanding", "label": "Confirmar brevemente o que entendeu" },
            { "id": "objective_questions", "label": "Fazer perguntas objetivas quando faltarem dados" },
            { "id": "clear_result", "label": "Apresentar resultado de forma clara" },
            { "id": "pending_items", "label": "Listar pendências" },
            { "id": "human_approval", "label": "Indicar quando é necessária aprovação humana" }
