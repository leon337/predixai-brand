          "id": "emoji_policy",
          "prompt": "O funcionário pode usar emojis?",
          "answerType": "single_select",
          "required": true,
          "suggestedAnswer": "minimal",
          "options": [
            { "id": "none", "label": "Não usar emojis" },
            { "id": "minimal", "label": "Usar raramente e apenas quando ajudar na clareza" },
            { "id": "moderate", "label": "Usar com moderação em saudações e confirmações" }
