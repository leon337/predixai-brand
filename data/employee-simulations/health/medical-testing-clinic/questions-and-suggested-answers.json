          "options": [
            { "id": "published_services", "label": "Catálogo fictício de exames e serviços" },
            { "id": "published_hours", "label": "Horários, canais e unidades fictícias" },
            { "id": "published_faq", "label": "Perguntas frequentes fictícias" },
            { "id": "published_policies", "label": "Políticas administrativas fictícias" },
            { "id": "published_scenarios", "label": "Cenários simulados aprovados" },
            { "id": "manual_session_information", "label": "Informações adicionais fornecidas manualmente durante a sessão" }
