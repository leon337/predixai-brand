  "questionnaireId": "health-medical-testing-clinic-aurora-questionnaire",
  "profileId": "health-medical-testing-clinic-aurora",
  "status": "draft_for_review",
  "fictional": true,
  "purpose": "Oferecer perguntas e respostas fictícias prontas para criar um Atendente de IA próximo de uma operação real, sem exigir que o usuário comece com campos vazios.",
  "interactionModes": [
    {
      "id": "use_suggested",
      "label": "Usar resposta sugerida"
    },
    {
      "id": "edit_suggested",
      "label": "Editar resposta"
    },
    {
      "id": "do_not_include",
      "label": "Não incluir no teste"
    }
  ],
  "sections": [
    {
      "id": "business_identity",
      "title": "Identidade do negócio",
      "description": "Confirma como a clínica fictícia será apresentada no prompt.",
      "questions": [
        {
          "id": "company_display_name",
          "prompt": "Qual nome a clínica deve usar durante o teste?",
          "answerType": "editable_text",
          "required": true,
          "suggestedAnswer": "Clínica Aurora Diagnósticos",
          "maxLength": 120,
          "includeInPromptAs": "company.displayName"
        },
        {
          "id": "business_description",
          "prompt": "Como a clínica deve ser descrita em uma frase?",
          "answerType": "editable_textarea",
          "required": true,
          "suggestedAnswer": "Clínica fictícia de exames e serviços de diagnóstico ambulatorial, criada para demonstrar um atendimento administrativo organizado, claro e seguro.",
          "maxLength": 280,
          "includeInPromptAs": "company.description"
        },
        {
          "id": "service_region",
          "prompt": "Qual área fictícia a clínica atende?",
          "answerType": "single_select",
          "required": true,
          "suggestedAnswer": "metropolitan_recife",
          "options": [
            { "id": "metropolitan_recife", "label": "Região Metropolitana do Recife — cenário fictício" },
            { "id": "city_only", "label": "Somente uma cidade fictícia" },
            { "id": "regional_service", "label": "Atendimento regional fictício" },
            { "id": "not_informed", "label": "Não informar no teste" }
          ],
          "includeInPromptAs": "company.serviceRegion"
        },
        {
          "id": "primary_audience",
          "prompt": "Quem é o público principal da clínica fictícia?",
          "answerType": "multi_select",
          "required": true,
          "suggestedAnswer": ["individual_patients", "family_representatives"],
          "options": [
            { "id": "individual_patients", "label": "Pessoas que buscam informações administrativas sobre exames" },
            { "id": "family_representatives", "label": "Familiares ou responsáveis" },
            { "id": "companies", "label": "Empresas com demandas ocupacionais fictícias" },
            { "id": "referring_professionals", "label": "Consultórios e profissionais que encaminham pacientes no cenário simulado" }
          ],
          "includeInPromptAs": "company.audiences"
        }
      ]
    },
