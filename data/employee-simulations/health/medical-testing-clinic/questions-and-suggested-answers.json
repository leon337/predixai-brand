            { "id": "low", "label": "Até 20 solicitações por dia" },
            { "id": "medium", "label": "Entre 20 e 60 solicitações por dia" },
            { "id": "high", "label": "Mais de 60 solicitações por dia" },
            { "id": "not_informed", "label": "Não informar no teste" }
