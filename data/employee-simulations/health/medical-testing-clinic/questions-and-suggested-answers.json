          "prompt": "Qual deve ser o tamanho padrão das respostas?",
          "answerType": "single_select",
          "required": true,
          "suggestedAnswer": "short_to_medium",
          "options": [
            { "id": "short", "label": "Curta e objetiva" },
            { "id": "short_to_medium", "label": "Curta a média, detalhando somente quando necessário" },
            { "id": "detailed", "label": "Detalhada e explicativa" }
