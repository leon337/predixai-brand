      "title": "Identidade do funcionário",
      "description": "Define como o Atendente de IA será identificado e apresentado.",
      "questions": [
        {
          "id": "employee_name",
          "prompt": "Qual nome o Atendente de IA deve usar?",
          "answerType": "editable_text",
          "required": true,
          "suggestedAnswer": "Clara",
          "maxLength": 60,
          "includeInPromptAs": "employee.name"
